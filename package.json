{
  "name": "minkin.tech",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run content:sync && node scripts/generate-public-static-assets.mjs",
    "dev": "vite",
    "content:sync": "node scripts/generate-github-content.mjs",
    "typecheck": "vue-tsc -b",
    "build": "node scripts/generate-github-content.mjs && vue-tsc -b && vite build && node scripts/postbuild-static-pages.mjs",
    "preview": "vite preview",
    "verify:content": "node scripts/verify-site.mjs",
    "verify:dist": "node scripts/verify-site.mjs --dist",
    "check": "npm run verify:content && npm run build && npm run verify:dist"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.6"
  }
}
